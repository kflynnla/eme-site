{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "eme-site",
  "compatibility_date": "2026-04-23",
  "compatibility_flags": [
    "global_fetch_strictly_public",
    "nodejs_compat"
  ],
  "main": "./dist/_worker.js/index.js",
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist"
  },
  "observability": {
    "enabled": true
  }
}
