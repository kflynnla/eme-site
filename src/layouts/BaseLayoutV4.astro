---
/**
 * V4 layout — same shell as BaseLayout but layers global-v4.css on
 * top to override color tokens via body.eme-v4 scope. Exists only
 * for side-by-side palette comparison; noindex until promoted.
 */
import '../styles/global.css';
import '../styles/global-v4.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  ogImage?: string;
  locale?: 'en' | 'fr' | 'es';
  noIndex?: boolean;
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  canonicalPath,
  ogImage = '/og/default.jpg',
  locale = 'en',
  noIndex = true,
  schema,
} = Astro.props;

const site = Astro.site?.toString().replace(/\/$/, '') ?? 'https://easilymovedequipment.com';
const path = canonicalPath ?? Astro.url.pathname;
const canonical = site + path;
const schemaJson = schema ? JSON.stringify(schema) : null;
---
<!doctype html>
<html lang={locale}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {noIndex && <meta name="robots" content="noindex, nofollow" />}

  <link rel="canonical" href={canonical} />

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={site + ogImage} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  {schemaJson && <script type="application/ld+json" is:inline set:html={schemaJson} />}
</head>
<body class="eme-v4">
  <Nav locale={locale} />
  <main><slot /></main>
  <Footer locale={locale} />
</body>
</html>
