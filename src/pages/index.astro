---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CertificationStrip from '../components/CertificationStrip.astro';
import CoverageMap from '../components/CoverageMap.astro';
import ProductLineGrid from '../components/ProductLineGrid.astro';
import IndustryGrid from '../components/IndustryGrid.astro';
import ShowcaseBand from '../components/ShowcaseBand.astro';
import CTABand from '../components/CTABand.astro';
// PillarStrip ("The eme Difference") lives on the About page (TBD),
// not the homepage — buyer-path shouldn't force differentiation reading.

/**
 * Homepage. All editable copy lives in src/content/homepage/index.json and is
 * edited through the Tina Cloud admin UI — no code changes required.
 */
const home = await getEntry('homepage', 'index');
if (!home) throw new Error('Missing src/content/homepage/index.json');
const h = home.data;

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Easily Moved Equipment',
  alternateName: 'eme',
  url: 'https://easilymovedequipment.com',
  logo: 'https://easilymovedequipment.com/logo.png',
  description: h.description,
  foundingDate: '2003',
  telephone: '+1-888-679-5283',
  sameAs: ['https://www.linkedin.com/company/easily-moved-equipment'],
};
---
<BaseLayout title={h.title} description={h.description} canonicalPath="/" schema={orgSchema}>

  <Hero
    overline={h.hero.overline}
    headline={h.hero.headline}
    subhead={h.hero.subhead}
    specs={h.hero.specs}
    primaryCta={h.hero.primaryCta}
    secondaryCta={h.hero.secondaryCta}
    imageBadge={h.hero.imageBadge}
    imageCaption={h.hero.imageCaption}
    imageSrc={h.hero.image}
  />

  <CertificationStrip />

  <ProductLineGrid cards={h.productCards} />

  <CoverageMap
    variant="compact"
    headline={h.coverageMap.headline}
    sub={h.coverageMap.sub}
    ctaLabel={h.coverageMap.ctaLabel}
    ctaHref={h.coverageMap.ctaHref}
  />

  <IndustryGrid industries={h.industryCards} />

  <ShowcaseBand
    label={h.showcase.label}
    headline={h.showcase.headline}
    body={h.showcase.body}
    ctaLabel={h.showcase.ctaLabel}
    ctaHref={h.showcase.ctaHref}
  />

  <CTABand
    headline={h.finalCta.headline}
    sub={h.finalCta.sub}
    primaryCta={h.finalCta.primary}
    secondaryCta={h.finalCta.secondary}
  />

</BaseLayout>
