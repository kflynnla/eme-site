---
interface Industry { title: string; line: string; href: string; }
interface Props { industries: Industry[]; label?: string; }
const { industries, label = 'Industries We Serve' } = Astro.props;
---
<section class="section section-eggshell">
  <div class="section-inner">
    <div class="section-label">{label}</div>
    <div class="industries-grid">
      {industries.map(i => (
        <a href={i.href} class="industry-card">
          <h3>{i.title}</h3>
          <p>{i.line}</p>
          <span class="card-cta">See solutions <span class="arrow">→</span></span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .section-inner > .section-label { margin-bottom: 48px; }
  .industries-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  .industry-card {
    background: var(--white);
    border: 1px solid var(--aluminum-light);
    padding: 28px 24px 24px;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s, transform 0.2s;
  }
  .industry-card:hover {
    border-color: var(--near-black);
    transform: translateY(-2px);
  }
  .industry-card h3 {
    font-size: 17px;
    font-weight: 700;
    color: var(--near-black);
    letter-spacing: -0.3px;
    line-height: 1.25;
    margin-bottom: 12px;
  }
  .industry-card p {
    font-size: 13px;
    line-height: 1.55;
    color: var(--graphite);
    flex: 1;
    margin-bottom: 20px;
  }
  .card-cta {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--near-black);
  }
  .card-cta .arrow { color: var(--red); margin-left: 4px; }
  @media (max-width: 1100px) { .industries-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .industries-grid { grid-template-columns: 1fr; } }
</style>
