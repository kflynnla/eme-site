---
/**
 * Five-pillar credibility strip — spec §2.3 and §4 Home.
 */
interface Pillar {
  icon: string;   // SVG path markup (viewBox="0 0 40 40"); supplied by caller
  title: string;
  body: string;
}
interface Props {
  label?: string;      // overline above strip — default: "The eme Difference"
  pillars: Pillar[];
}
const { label = 'The eme Difference', pillars } = Astro.props;
---
<section class="pillars">
  <div class="section-label">{label}</div>
  <div class="pillars-inner">
    {pillars.map(p => (
      <div class="pillar">
        <div class="pillar-icon" set:html={p.icon} />
        <h3 class="pillar-title">{p.title}</h3>
        <p class="pillar-body">{p.body}</p>
      </div>
    ))}
  </div>
</section>

<style>
  .pillars {
    background: var(--white);
    padding: 110px 48px 120px;
    border-top: 1px solid var(--aluminum-light);
    border-bottom: 1px solid var(--aluminum-light);
  }
  .section-label { max-width: 1280px; margin: 0 auto 70px; }
  .pillars-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 40px;
  }
  .pillar {
    padding-right: 20px;
    border-right: 1px solid var(--aluminum-light);
  }
  .pillar:last-child { border-right: none; padding-right: 0; }
  .pillar-icon {
    width: 40px;
    height: 40px;
    margin-bottom: 28px;
    color: var(--near-black);
  }
  .pillar-icon :global(svg) {
    width: 40px;
    height: 40px;
    stroke: currentColor;
    stroke-width: 1.3;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .pillar-title {
    font-weight: 700;
    font-size: 17px;
    line-height: 1.25;
    color: var(--near-black);
    margin-bottom: 18px;
    letter-spacing: -0.4px;
  }
  .pillar-body {
    font-size: 13px;
    line-height: 1.6;
    color: var(--graphite);
  }

  @media (max-width: 1100px) {
    .pillars-inner { gap: 28px; }
    .pillar-body { font-size: 12.5px; }
  }
  @media (max-width: 900px) {
    .pillars { padding: 72px 20px; }
    .pillars-inner { grid-template-columns: repeat(2, 1fr); gap: 40px; }
    .pillar:nth-child(odd) { border-right: 1px solid var(--aluminum-light); }
    .pillar:nth-child(even), .pillar:last-child { border-right: none; padding-right: 0; }
  }
  @media (max-width: 560px) {
    .pillars-inner { grid-template-columns: 1fr; }
    .pillar { border-right: none !important; padding-right: 0; padding-bottom: 32px; border-bottom: 1px solid var(--aluminum-light); }
    .pillar:last-child { border-bottom: none; padding-bottom: 0; }
  }
</style>
