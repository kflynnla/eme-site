---
/**
 * Final page-level CTA band. Sits at the bottom of long pages.
 */
interface Props {
  headline: string;
  sub?: string;
  primaryCta: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  variant?: 'light' | 'dark';
}
const { headline, sub, primaryCta, secondaryCta, variant = 'light' } = Astro.props;
---
<section class={`cta-band ${variant}`}>
  <div class="cta-band-inner">
    <h2>{headline}</h2>
    {sub && <p>{sub}</p>}
    <div class="cta-band-buttons">
      <a href={primaryCta.href} class={variant === 'dark' ? 'btn btn-on-dark' : 'btn btn-primary'}>
        {primaryCta.label}<span class="arrow">→</span>
      </a>
      {secondaryCta && (
        <a href={secondaryCta.href} class="btn btn-secondary">{secondaryCta.label}<span class="arrow">→</span></a>
      )}
    </div>
  </div>
</section>

<style>
  .cta-band {
    padding: 100px 48px;
    background: var(--white);
    border-top: 1px solid var(--aluminum-light);
    text-align: center;
  }
  .cta-band.dark {
    background: var(--near-black);
    color: var(--white);
    border-top: none;
  }
  .cta-band-inner { max-width: 900px; margin: 0 auto; }
  h2 { margin-bottom: 20px; }
  .cta-band.dark h2 { color: var(--white); }
  p {
    font-size: 17px;
    line-height: 1.5;
    color: var(--graphite);
    margin-bottom: 36px;
    max-width: 620px;
    margin-left: auto;
    margin-right: auto;
  }
  .cta-band.dark p { color: var(--aluminum-light); }
  .cta-band-buttons { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
  @media (max-width: 900px) { .cta-band { padding: 72px 20px; } }
</style>
