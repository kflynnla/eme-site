---
/**
 * V3 CertificationStrip — small tracked header + 7 tight code boxes
 * on a single row. Sub-line copy per Kyle's spec 2026-04-23.
 */
const codes = [
  { code: 'ASME B30.17',   line: 'Cranes & Monorails' },
  { code: 'ASME BTH-1',    line: 'Design of Below-the-Hook Lifting Devices' },
  { code: 'ASME B30.20',   line: 'Below-the-Hook Lifting Devices' },
  { code: 'OSHA 1910.179', line: 'Overhead and Gantry Cranes' },
  { code: 'CSA B167',      line: 'Overhead travelling cranes' },
  { code: 'CSA S157',      line: 'Strength Design in Aluminum' },
  { code: 'CSA W47.2',     line: 'Fusion Welding of Aluminum (CWB)' },
];
---
<section class="certs">
  <div class="certs-inner">
    <div class="certs-eyebrow">Designed to Meet North American Standards</div>
    <div class="certs-grid">
      {codes.map(c => (
        <div class="cert">
          <div class="cert-code">{c.code}</div>
          <div class="cert-body">{c.line}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .certs {
    background: var(--paper);
    border-top: 1px solid var(--aluminum-light);
    border-bottom: 1px solid var(--aluminum-light);
  }
  .certs-inner {
    max-width: var(--container);
    margin: 0 auto;
    padding: 44px var(--gutter);
  }
  .certs-eyebrow {
    font-family: var(--mono);         /* = Inter in V3 */
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--aluminum-dark);
    margin-bottom: 18px;
  }
  .certs-grid {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: 8px;
  }
  .cert {
    background: var(--white);
    border: 1px solid var(--aluminum-light);
    padding: 13px 12px;
    transition: border-color 0.2s;
    min-width: 0;
  }
  .cert:hover { border-color: var(--near-black); }

  .cert-code {
    font-family: var(--sans-display);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--near-black);
    margin-bottom: 4px;
    white-space: nowrap;
  }
  .cert-body {
    font-family: var(--sans);
    font-size: 11.5px;
    font-weight: 400;
    line-height: 1.35;
    color: var(--graphite);
  }

  @media (max-width: 1100px) {
    .certs-grid { grid-template-columns: repeat(4, 1fr); gap: 10px; }
    .cert { padding: 14px 14px; }
    .cert-code { font-size: 14px; }
    .cert-body { font-size: 12.5px; }
  }
  @media (max-width: 700px) {
    .certs-inner { padding: 36px var(--gutter-mobile); }
    .certs-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 420px) {
    .certs-grid { grid-template-columns: 1fr; }
  }
</style>
