---
/**
 * V3 CertificationStrip — V1's full code list presented as individual
 * V3 boxes. No section heading (per Kyle: "anyone looking for codes
 * will know exactly what we are referring to"). All text in Lexend
 * and Inter — no mono.
 *
 * Seven standards, one box each:
 *   ASME B30.17, ASME BTH-1, ASME B30.20, OSHA 1910.179,
 *   CSA B167, CSA S157, CSA W47.2
 */
const codes = [
  { code: 'ASME B30.17',   line: 'Overhead & Gantry Cranes' },
  { code: 'ASME BTH-1',    line: 'Below-the-Hook Lifting Design' },
  { code: 'ASME B30.20',   line: 'Below-the-Hook Safety Standard' },
  { code: 'OSHA 1910.179', line: 'Overhead & Gantry Cranes (US)' },
  { code: 'CSA B167',      line: 'Cranes, Hoists & Rigging (Canada)' },
  { code: 'CSA S157',      line: 'Strength Design in Aluminum' },
  { code: 'CSA W47.2',     line: 'Fusion Welding of Aluminum (CWB)' },
];
---
<section class="certs">
  <div class="certs-inner">
    <div class="certs-grid">
      {codes.map(c => (
        <div class="cert">
          <div class="cert-code">{c.code}</div>
          <div class="cert-body">{c.line}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .certs {
    background: var(--paper);
    border-top: 1px solid var(--aluminum-light);
    border-bottom: 1px solid var(--aluminum-light);
  }
  .certs-inner {
    max-width: var(--container);
    margin: 0 auto;
    padding: 64px var(--gutter);
  }
  .certs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
  }
  .cert {
    background: var(--white);
    border: 1px solid var(--aluminum-light);
    padding: 22px 20px;
    transition: border-color 0.2s;
  }
  .cert:hover { border-color: var(--near-black); }

  .cert-code {
    font-family: var(--sans-display);
    font-size: 17px;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--near-black);
    margin-bottom: 6px;
  }
  .cert-body {
    font-family: var(--sans);
    font-size: 13.5px;
    font-weight: 400;
    line-height: 1.45;
    color: var(--graphite);
  }

  @media (max-width: 900px) {
    .certs-inner { padding: 48px var(--gutter-mobile); }
    .certs-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 420px) {
    .certs-grid { grid-template-columns: 1fr; }
  }
</style>
