---
/**
 * V2 IndustryGrid — 8-cell industries-served grid with hairline dividers,
 * text-only (no decorative icons), sharp corners. Monochrome.
 */
interface Industry { title: string; line: string; href: string; }
interface Props { industries: Industry[]; }
const { industries } = Astro.props;
---
<section class="industries">
  <div class="industries-inner">
    <div class="industries-head">
      <div class="eme-eyebrow">Industries Served</div>
      <h2 class="industries-heading">Wherever a Crane Truck Can't Go.</h2>
    </div>

    <div class="industries-grid">
      {industries.map(i => (
        <a href={i.href} class="industry">
          <h3 class="industry-title">{i.title}</h3>
          <p class="industry-body">{i.line}</p>
          <span class="industry-arrow" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="square"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .industries { background: var(--bg-1); border-top: 1px solid var(--border-1); border-bottom: 1px solid var(--border-1); }
  .industries-inner { max-width: var(--container); margin: 0 auto; padding: var(--space-8) var(--gutter); }
  .industries-head { display: flex; flex-direction: column; gap: var(--space-3); margin-bottom: var(--space-7); }
  .industries-heading {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.4vw, 40px);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0;
    max-width: 22ch;
  }

  .industries-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid var(--fg-1);
    border-left: 1px solid var(--border-1);
  }

  .industry {
    position: relative;
    padding: var(--space-6) var(--space-5);
    border-right: 1px solid var(--border-1);
    border-bottom: 1px solid var(--border-1);
    color: inherit;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    background: var(--bg-1);
    transition: background var(--dur-base) var(--ease-out);
  }
  .industry:hover { background: var(--bg-2); }

  .industry-title {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.2;
    color: var(--fg-1);
    margin: 0;
  }
  .industry-body {
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--fg-2);
    margin: 0;
  }
  .industry-arrow {
    color: var(--fg-3);
    align-self: flex-end;
    margin-top: auto;
  }
  .industry:hover .industry-arrow { color: var(--fg-1); }

  @media (max-width: 1100px) {
    .industries-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .industries-grid { grid-template-columns: 1fr; }
  }
</style>
