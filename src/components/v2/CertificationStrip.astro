---
/**
 * V2 certification strip — per handoff chat, cert rows appear BELOW a
 * 1px ink rule with explanatory copy at 16/14 (title/body), because this
 * content is what earns trust with spec buyers and shouldn't be caption-hidden.
 */
const certs = [
  {
    svg: '/v2-assets/cert-asme.svg',
    alt: 'ASME B30.17 certified',
    code: 'ASME B30.17 · BTH-1',
    body: 'Overhead and Gantry Cranes (single girder, under-running hoists); Design of Below-the-Hook Lifting Devices. The two ASME standards an aluminum gantry has to meet.',
  },
  {
    svg: '/v2-assets/cert-csa.svg',
    alt: 'CSA B167 · S157 certified',
    code: 'CSA B167 · S157',
    body: 'Canadian safety code for cranes and hoists; Canadian standard for strength design in aluminum. Enforces that aluminum structures are calculated correctly for load.',
  },
  {
    svg: '/v2-assets/cert-cwb.svg',
    alt: 'CSA W47.2 certified by CWB',
    code: 'CSA W47.2',
    body: 'Fusion welding of aluminum. Every eme frame is welded by CWB-certified welders under the Canadian Welding Bureau — a traceable chain of custody on every joint.',
  },
];
---
<section class="certs">
  <div class="certs-inner">
    <h2 class="certs-heading">Designed to North American Codes.</h2>
    <hr class="eme-rule eme-rule--strong" />
    <div class="certs-grid">
      {certs.map(c => (
        <div class="cert">
          <img src={c.svg} alt={c.alt} class="cert-mark" />
          <div class="cert-code">{c.code}</div>
          <p class="cert-body">{c.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .certs { background: var(--bg-1); border-top: 1px solid var(--border-1); border-bottom: 1px solid var(--border-1); }
  .certs-inner { max-width: var(--container); margin: 0 auto; padding: var(--space-8) var(--gutter); }
  .certs-heading {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.4vw, 40px);
    font-weight: 900;
    letter-spacing: var(--ls-tight);
    line-height: 1.02;
    margin: 0 0 var(--space-5);
  }
  .certs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    padding-top: var(--space-6);
  }
  .cert-mark { height: 56px; width: auto; margin-bottom: var(--space-4); filter: grayscale(1); }
  .cert-code {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--fg-1);
    margin-bottom: 6px;
    text-transform: uppercase;
  }
  .cert-body {
    font-size: 14px;
    line-height: 1.55;
    color: var(--fg-2);
    max-width: 38ch;
    margin: 0;
  }

  @media (max-width: 900px) {
    .certs-grid { grid-template-columns: 1fr; gap: var(--space-5); }
  }
</style>
