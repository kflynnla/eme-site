---
/**
 * V2 ShowcaseBand — inverse (dark) section with heavy ink background,
 * large Plex Condensed headline, paper-color body, CTA on dark.
 * Red only appears on the primary CTA fill (structural).
 */
interface Props {
  label?: string;
  headline: string;
  body: string;
  ctaLabel: string;
  ctaHref: string;
}
const { label, headline, body, ctaLabel, ctaHref } = Astro.props;
---
<section class="showcase">
  <div class="showcase-inner">
    {label && <div class="eme-eyebrow showcase-eyebrow">{label}</div>}
    <h2 class="showcase-heading">{headline}</h2>
    <p class="showcase-body">{body}</p>
    <a href={ctaHref} class="eme-btn eme-btn--on-dark">
      {ctaLabel}
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="square"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
    </a>
  </div>
</section>

<style>
  .showcase {
    background: var(--bg-inverse);
    color: var(--fg-on-dark);
    border-top: 1px solid var(--fg-1);
    position: relative;
    overflow: hidden;
  }
  .showcase::before {
    content: '';
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(182,187,194,0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(182,187,194,0.06) 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none;
  }
  .showcase-inner {
    position: relative;
    max-width: var(--container);
    margin: 0 auto;
    padding: var(--space-9) var(--gutter);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    align-items: flex-start;
  }
  .showcase-eyebrow {
    color: var(--eme-aluminum);
  }
  .showcase-heading {
    font-family: var(--font-display);
    font-size: clamp(32px, 4.6vw, 56px);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.08;
    color: var(--eme-white);
    max-width: 22ch;
    margin: 0;
  }
  .showcase-body {
    font-size: 17px;
    line-height: 1.6;
    color: var(--eme-aluminum);
    max-width: 62ch;
    margin: 0 0 var(--space-4);
  }
</style>
