---
/**
 * V2 Hero — Plex Condensed mega headline, Plex Sans subhead,
 * spec strip with mega numerics (tabular-nums), live-on-jobsite pip,
 * two-column with warm-mono treated image, strong ink top rule above spec strip.
 */
interface Spec { label: string; value: string; }
interface Props {
  overline: string;
  headline: string;      // <br> supported
  subhead: string;
  specs?: Spec[];
  primaryCta: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  imageBadge?: string;
  imageCaption?: string;
  imageSrc?: string;
}
const { overline, headline, subhead, specs, primaryCta, secondaryCta, imageBadge, imageCaption, imageSrc } = Astro.props;

// Fallback to the design-system jobsite placeholder if no image is configured yet
const heroImage = imageSrc || '/v2-assets/jobsite-placeholder.svg';

// Drop the leading "Portable Aluminum Lifting · Est. 2003" style overline into
// a pip + est-year split so we get the ● pulse on "Live on jobsite"
---
<section class="hero">
  <div class="spec-bg" aria-hidden="true"></div>
  <div class="hero-inner">
    <div class="hero-text">
      <div class="hero-overline">
        <span class="eme-pip">Live on Jobsite</span>
        <span class="hero-est">· {overline.replace(/^[^·]*·\s*/, '')}</span>
      </div>

      <h1 class="hero-headline" set:html={headline} />

      <p class="hero-subhead">{subhead}</p>

      <div class="hero-ctas">
        <a href={primaryCta.href} class="eme-btn eme-btn--primary">
          {primaryCta.label}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="square"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        {secondaryCta && (
          <a href={secondaryCta.href} class="eme-btn eme-btn--secondary">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="square"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
            {secondaryCta.label}
          </a>
        )}
      </div>

      {specs && specs.length > 0 && (
        <div class="hero-specs">
          {specs.map((s, i) => (
            <div class="hero-spec" data-last={i === specs.length - 1}>
              <span class="hero-spec-label">{s.label}</span>
              <div class="hero-spec-value">{s.value}</div>
            </div>
          ))}
        </div>
      )}
    </div>

    <div class="hero-image" style={`background-image: url(${heroImage});`}>
      {imageBadge && <span class="hero-image-badge">{imageBadge}</span>}
      {imageCaption && <span class="hero-image-caption">{imageCaption}</span>}
    </div>
  </div>
</section>

<style>
  .hero { position: relative; background: var(--bg-1); }
  .spec-bg {
    position: absolute; inset: 0; opacity: 0.35;
    background-image:
      linear-gradient(var(--border-1) 1px, transparent 1px),
      linear-gradient(90deg, var(--border-1) 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    max-width: var(--container);
    margin: 0 auto;
    padding: var(--space-8) var(--gutter) var(--space-9);
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 1fr);
    gap: 72px;
    align-items: center;
  }

  .hero-overline {
    display: flex; align-items: center; gap: 12px;
    margin-bottom: var(--space-5);
  }
  .hero-est {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    color: var(--fg-3);
    text-transform: uppercase;
  }

  .hero-headline {
    font-family: var(--font-display);
    font-size: clamp(56px, 8vw, 112px);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.02;
    color: var(--fg-1);
    max-width: 1100px;
    margin: 0 0 var(--space-5);
    text-wrap: balance;
  }

  .hero-subhead {
    font-size: 18px;
    line-height: 1.55;
    color: var(--fg-2);
    max-width: 620px;
    margin: 0 0 var(--space-6);
  }

  .hero-ctas { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: var(--space-8); }

  .hero-specs {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid var(--fg-1);          /* strong ink top rule */
    border-bottom: 1px solid var(--border-1);   /* hairline aluminum bottom */
    max-width: 720px;
  }
  .hero-spec {
    padding: 22px 24px 22px 0;
    border-right: 1px solid var(--border-1);
  }
  .hero-spec[data-last="true"] { border-right: none; }
  .hero-spec:not(:first-child) { padding-left: 24px; }
  .hero-spec-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fg-2);
  }
  .hero-spec-value {
    font-family: var(--font-display);
    font-size: clamp(24px, 2.4vw, 32px);
    font-weight: 700;
    letter-spacing: -0.015em;
    line-height: 1.05;
    color: var(--fg-1);
    font-variant-numeric: tabular-nums;
    margin-top: 10px;
  }

  .hero-image {
    position: relative;
    aspect-ratio: 4 / 5;
    background-size: cover;
    background-position: center;
    background-color: var(--eme-ink);
    filter: var(--photo-treatment);
    border: 1px solid var(--border-1);
    overflow: hidden;
  }
  .hero-image::after {
    content: '';
    position: absolute; inset: 0;
    background: rgba(13,15,18,0.25);
  }
  .hero-image-badge {
    position: absolute;
    top: 16px; left: 16px;
    padding: 6px 10px;
    background: rgba(13,15,18,0.72);
    color: var(--fg-on-dark);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    backdrop-filter: blur(4px);
    z-index: 2;
    filter: none;  /* don't apply photo filter to UI chrome */
  }
  .hero-image-caption {
    position: absolute;
    bottom: 16px; left: 16px; right: 16px;
    color: var(--eme-aluminum);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    z-index: 2;
  }

  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; gap: 48px; padding: var(--space-7) 20px; }
    .hero-image { aspect-ratio: 16 / 10; }
  }
  @media (max-width: 560px) {
    .hero-specs { grid-template-columns: 1fr 1fr; }
    .hero-spec:nth-child(2) { border-right: none; }
    .hero-spec:nth-child(3) {
      grid-column: 1 / -1;
      border-top: 1px solid var(--border-1);
      padding-left: 0;
    }
  }
</style>
