---
/**
 * V2 PillarStrip — "The eme Difference" five-up grid with ruled dividers,
 * line-icon + title + body. No typographic red; icons are steel-stroke.
 */
import type { Pillar } from '../../data/pillars';
interface Props { label: string; pillars: Pillar[]; }
const { label, pillars } = Astro.props;
---
<section class="pillars">
  <div class="pillars-inner">
    <div class="eme-eyebrow">{label}</div>

    <div class="pillars-grid">
      {pillars.map((p) => (
        <div class="pillar">
          <div class="pillar-icon" set:html={p.icon} />
          <h3 class="pillar-title">{p.title}</h3>
          <p class="pillar-body">{p.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .pillars { background: var(--bg-1); border-top: 1px solid var(--border-1); border-bottom: 1px solid var(--border-1); }
  .pillars-inner { max-width: var(--container); margin: 0 auto; padding: var(--space-8) var(--gutter); }
  .pillars-inner .eme-eyebrow { margin-bottom: var(--space-7); }

  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(var(--cols, 5), 1fr);
    border-top: 1px solid var(--fg-1);
  }
  .pillar {
    padding: var(--space-6) var(--space-5) var(--space-6) 0;
    border-right: 1px solid var(--border-1);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .pillar:not(:first-child) { padding-left: var(--space-5); }
  .pillar:last-child { border-right: none; padding-right: 0; }

  .pillar-icon {
    width: 40px; height: 40px;
    color: var(--fg-2);
    stroke: currentColor;
    fill: none;
    stroke-width: 1.5;
  }
  .pillar-icon :global(svg) { width: 100%; height: 100%; stroke: currentColor; stroke-width: 1.5; fill: none; }
  .pillar-icon :global(text) { stroke: none; fill: currentColor; }

  .pillar-title {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.2;
    color: var(--fg-1);
    margin: 0;
  }
  .pillar-body {
    font-size: 14px;
    line-height: 1.55;
    color: var(--fg-2);
    margin: 0;
  }

  @media (max-width: 1100px) {
    .pillars-grid { grid-template-columns: repeat(3, 1fr); }
    .pillar:nth-child(3) { border-right: none; padding-right: 0; }
    .pillar:nth-child(4),
    .pillar:nth-child(5) { border-top: 1px solid var(--border-1); }
    .pillar:nth-child(4) { padding-left: 0; }
  }
  @media (max-width: 700px) {
    .pillars-grid { grid-template-columns: 1fr; }
    .pillar { border-right: none; border-bottom: 1px solid var(--border-1); padding: var(--space-5) 0; }
    .pillar:last-child { border-bottom: none; }
  }
</style>
