---
/**
 * V2 CTABand — final conversion strip. Paper ground, ruled top+bottom,
 * heading + sub + two CTAs (primary red, secondary ink-outline).
 */
interface Props {
  headline: string;
  sub: string;
  primaryCta: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
}
const { headline, sub, primaryCta, secondaryCta } = Astro.props;
---
<section class="cta">
  <div class="cta-inner">
    <h2 class="cta-heading">{headline}</h2>
    <p class="cta-sub">{sub}</p>
    <div class="cta-actions">
      <a href={primaryCta.href} class="eme-btn eme-btn--primary">
        {primaryCta.label}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="square"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
      {secondaryCta && (
        <a href={secondaryCta.href} class="eme-btn eme-btn--secondary">
          {secondaryCta.label}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="square"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      )}
    </div>
  </div>
</section>

<style>
  .cta { background: var(--bg-1); border-top: 1px solid var(--border-1); border-bottom: 1px solid var(--border-1); }
  .cta-inner {
    max-width: var(--container);
    margin: 0 auto;
    padding: var(--space-9) var(--gutter);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    align-items: flex-start;
    max-width: 820px;
  }
  .cta-heading {
    font-family: var(--font-display);
    font-size: clamp(32px, 4.4vw, 56px);
    font-weight: 900;
    letter-spacing: var(--ls-tight);
    line-height: 0.98;
    color: var(--fg-1);
    margin: 0;
  }
  .cta-sub {
    font-family: var(--font-body);
    font-size: 20px;
    font-weight: 300;
    line-height: 1.55;
    color: var(--fg-2);
    max-width: 62ch;
    margin: 0 0 var(--space-3);
  }
  .cta-actions { display: flex; gap: 14px; flex-wrap: wrap; }
</style>
