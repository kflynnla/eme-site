---
/**
 * V2 ProductLineGrid — 4-up product category cards. Border-only (no shadow),
 * sharp-ish corners (--r-soft), mono-uppercase capacity chip, Plex title.
 */
interface Card { title: string; capacity: string; line: string; href: string; ctaLabel: string; }
interface Props { cards: Card[]; }
const { cards } = Astro.props;
---
<section class="line">
  <div class="line-inner">
    <div class="line-head">
      <div class="eme-eyebrow">Product Line</div>
      <h2 class="line-heading">Portable Aluminum Lifting, Every Capacity.</h2>
    </div>

    <div class="line-grid">
      {cards.map(c => (
        <a href={c.href} class="line-card">
          <div class="line-card-top">
            <span class="line-card-chip">{c.capacity}</span>
          </div>
          <h3 class="line-card-title">{c.title}</h3>
          <p class="line-card-body">{c.line}</p>
          <span class="line-card-cta">
            {c.ctaLabel}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="square"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .line { background: var(--bg-2); border-top: 1px solid var(--border-1); border-bottom: 1px solid var(--border-1); }
  .line-inner { max-width: var(--container); margin: 0 auto; padding: var(--space-8) var(--gutter); }
  .line-head { display: flex; flex-direction: column; gap: var(--space-3); margin-bottom: var(--space-7); }
  .line-heading {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.4vw, 40px);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0;
    max-width: 22ch;
  }

  .line-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
  }

  .line-card {
    background: var(--bg-card);
    border: 1px solid var(--border-1);
    border-radius: var(--r-soft);
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    color: inherit;
    text-decoration: none;
    transition: border-color var(--dur-base) var(--ease-out);
  }
  .line-card:hover { border-color: var(--fg-1); }
  .line-card-top { display: flex; }
  .line-card-chip {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fg-1);
    padding: 4px 9px;
    border: 1px solid var(--border-1);
  }
  .line-card-title {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.15;
    color: var(--fg-1);
    margin: 0;
  }
  .line-card-body {
    font-size: 14px;
    line-height: 1.55;
    color: var(--fg-2);
    margin: 0;
  }
  .line-card-cta {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    color: var(--fg-1);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: auto;
    padding-top: var(--space-3);
    border-top: 1px solid var(--border-1);
  }

  @media (max-width: 1100px) {
    .line-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .line-grid { grid-template-columns: 1fr; }
  }
</style>
