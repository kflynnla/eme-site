---
/**
 * Lockup — Bookman `eme` centered over "EASILY MOVED EQUIPMENT"
 * descender in Lexend tracked caps. No rule separator (removed
 * 2026-04-24 per Kyle: the extended red line read as "ridiculous"
 * at nav scale since align-self:stretch made it wider than `eme`).
 * Visual hierarchy now comes from the Bookman/Lexend typographic
 * contrast alone, not a painted divider.
 */
interface Props {
  size?: number;
  showName?: boolean;
  onDark?: boolean;
}
const { size = 26, showName = true, onDark = false } = Astro.props;
const color = onDark ? 'var(--paper)' : 'var(--near-black)';
---
<span class="lockup" style={`--lk-size:${size}px; --lk-color:${color}`}>
  <span class="lockup-mark">eme</span>
  {showName && <span class="lockup-name">Easily Moved Equipment</span>}
</span>

<style>
  .lockup {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    line-height: 1;
    color: var(--lk-color);
    text-align: center;
  }
  .lockup-mark {
    font-family: var(--serif);
    font-weight: 700;
    font-size: var(--lk-size);
    letter-spacing: -0.01em;
  }
  .lockup-name {
    font-family: var(--sans-display);
    font-weight: 700;
    font-size: max(9px, calc(var(--lk-size) * 0.32));
    letter-spacing: 0.22em;
    text-transform: uppercase;
    white-space: nowrap;
    margin-top: calc(var(--lk-size) * 0.18);
  }
</style>
