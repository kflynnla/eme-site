---
/**
 * Homepage product-line overview grid — spec §4 Home.
 * Four cards: Gantry Cranes, Davit Cranes, Eagle Beam, Accessories.
 */
interface Card {
  title: string;
  line: string;       // one-line value prop
  capacity: string;   // capacity range string
  href: string;
  ctaLabel: string;
}
interface Props { cards: Card[]; }
const { cards } = Astro.props;
---
<section class="section">
  <div class="section-inner">
    <div class="section-label">Product Line</div>
    <div class="product-grid">
      {cards.map(c => (
        <a href={c.href} class="product-card">
          <div class="product-card-art" aria-hidden="true">
            <span class="product-card-placeholder">Product Photo</span>
          </div>
          <div class="product-card-body">
            <div class="product-card-capacity">{c.capacity}</div>
            <h3 class="product-card-title">{c.title}</h3>
            <p class="product-card-line">{c.line}</p>
            <span class="product-card-cta">{c.ctaLabel} <span class="arrow">→</span></span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .section-inner > .section-label { margin-bottom: 48px; }
  .product-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  .product-card {
    display: flex;
    flex-direction: column;
    background: var(--white);
    border: 1px solid var(--aluminum-light);
    text-decoration: none;
    transition: border-color 0.2s, transform 0.2s;
  }
  .product-card:hover {
    border-color: var(--near-black);
    transform: translateY(-2px);
  }
  .product-card-art {
    aspect-ratio: 4 / 3;
    background: linear-gradient(145deg, #D4D7DC 0%, #EFF1F3 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid var(--aluminum-light);
  }
  .product-card-placeholder {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 1.5px;
    color: var(--aluminum-dark);
    text-transform: uppercase;
  }
  .product-card-body { padding: 24px; }
  .product-card-capacity {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.8px;
    color: var(--red);
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .product-card-title {
    font-weight: 700;
    font-size: 18px;
    color: var(--near-black);
    margin-bottom: 10px;
    letter-spacing: -0.4px;
  }
  .product-card-line {
    font-size: 13px;
    line-height: 1.55;
    color: var(--graphite);
    margin-bottom: 20px;
  }
  .product-card-cta {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--near-black);
  }
  .product-card-cta .arrow { color: var(--red); margin-left: 4px; }

  @media (max-width: 1100px) {
    .product-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .product-grid { grid-template-columns: 1fr; }
  }
</style>
